<div class="container mx-auto">
    <h2 class="font-display text-4xl max-w-[35rem] mb-14">{{ section.title }}</h2>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
        <!-- Colonne de gauche (fondateur) - 5/12 sur desktop -->
        <div class="lg:col-span-5 bg-neutral-900 rounded-2xl flex flex-col lg:flex-row items-stretch shadow-lg overflow-hidden">
            <!-- Image -->
            <div class="relative w-full lg:w-1/2 h-64 lg:h-auto bg-cover bg-center before:content-[''] before:absolute before:inset-0 before:bg-gradient-to-b before:from-black/65 before:to-black/85 before:grayscale after:content-[''] after:absolute after:inset-0 after:bg-black after:mix-blend-color">
                <img src="/public{{ section.founders.image[0].url }}" alt="Photo de {{ section.founders.name }}" class="w-full h-full object-cover" />
            </div>
            <!-- Contenu du fondateur -->
            <div class="p-6 md:p-9 flex flex-col justify-between flex-1 text-gray-300">
                <div>
                    <h3 class="font-display text-xl md:text-2xl mb-3 text-white text-center lg:text-left">{{ section.founders.name }}</h3>
                    <p class="text-neutral-400 text-sm mb-3 text-center lg:text-left">{{ section.founders.role }}</p>
                    <p class="text-neutral-400 text-sm mb-4 text-center lg:text-left">{{ section.founders.description }}</p>
                </div>
                <!-- Liens sociaux -->
                <div class="flex justify-center lg:justify-start gap-4 mt-4 text-sm">
                    {% for social in section.founders.social %} {% if social.social == "Linkedin" %}
                    <!-- Exemple pour Linkedin -->
                        <a class="flex items-center gap-2 hover:text-white transition underline-offset-4 underline" href="{{ social.link }}"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0,0,256,256" class="">
                            <g fill="#facc15" fill-rule="nonzero" stroke="none" stroke-width="1" stroke-linecap="butt" stroke-linejoin="miter" stroke-miterlimit="10" stroke-dasharray="" stroke-dashoffset="0" font-family="none" font-weight="none" font-size="none" text-anchor="none" style="mix-blend-mode: normal">
                                <g transform="scale(8.53333,8.53333)">
                                    <path d="M24,4h-18c-1.105,0 -2,0.895 -2,2v18c0,1.105 0.895,2 2,2h18c1.105,0 2,-0.895 2,-2v-18c0,-1.105 -0.895,-2 -2,-2zM10.954,22h-2.95v-9.492h2.95zM9.449,11.151c-0.951,0 -1.72,-0.771 -1.72,-1.72c0,-0.949 0.77,-1.719 1.72,-1.719c0.948,0 1.719,0.771 1.719,1.719c0,0.949 -0.771,1.72 -1.719,1.72zM22.004,22h-2.948v-4.616c0,-1.101 -0.02,-2.517 -1.533,-2.517c-1.535,0 -1.771,1.199 -1.771,2.437v4.696h-2.948v-9.492h2.83v1.297h0.04c0.394,-0.746 1.356,-1.533 2.791,-1.533c2.987,0 3.539,1.966 3.539,4.522z"></path>
                                </g>
                            </g>
                        </svg>
                        LinkedIn</a>
                    {% endif %} {% if social.social == "Facebook" %}
                    <!-- Exemple pour Facebook -->
                        <a  class="flex items-center gap-2 hover:text-white transition underline-offset-4 underline" href="{{ social.link }}"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0,0,256,256" class="">
                            <g fill="#facc15" fill-rule="nonzero" stroke="none" stroke-width="1" stroke-linecap="butt" stroke-linejoin="miter" stroke-miterlimit="10" stroke-dasharray="" stroke-dashoffset="0" font-family="none" font-weight="none" font-size="none" text-anchor="none" style="mix-blend-mode: normal">
                                <g transform="scale(5.12,5.12)">
                                    <path d="M41,4h-32c-2.76,0 -5,2.24 -5,5v32c0,2.76 2.24,5 5,5h32c2.76,0 5,-2.24 5,-5v-32c0,-2.76 -2.24,-5 -5,-5zM37,19h-2c-2.14,0 -3,0.5 -3,2v3h5l-1,5h-4v15h-5v-15h-4v-5h4v-3c0,-4 2,-7 6,-7c2.9,0 4,1 4,1z"></path>
                                </g>
                            </g>
                        </svg>
                        Facebook</a>
                    {% endif %} {% endfor %}
                </div>
            </div>
        </div>
        <!-- Colonne de droite (cartes) - Full width sur mobile, 7/12 sur desktop -->
        <div class="lg:col-span-7 bg-neutral-900 p-6 md:p-9 rounded-2xl flex flex-col justify-between">
            <!-- Contenu en haut -->
                    <div class="mb-7">
            <span class="texte-sm text-neutral-300">Notre vision</span>
        </div>
            <div>
                <h3 class="font-display text-3xl mb-4">{{ section.cards.title }}</h3>
                <p class="text-neutral-400 mb-6 md:mb-7 text-sm">{{ section.cards.description }}</p>
            </div>
            <div class="flex items-center gap-4 w-full">
                <!-- Champ email -->
                <input type="email" placeholder="Votre email" class="w-full max-w-96 bg-neutral-850 text-white text-xl placeholder:text-neutral-600 py-3 px-3 rounded-md" />
                <!-- Bouton -->
                <a href="{{ section.cards.button.link }}" class="inline-flex items-center rounded-lg bg-yellow-400 text-black py-3 px-3 hover:bg-yellow-300 transition-all duration-300 w-min">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</div>